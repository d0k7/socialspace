# ================================================================
# SocialSpace Backend — Environment Variables
# ================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.
# ================================================================

# ----------------------------------------------------------------
# Authentication
# ----------------------------------------------------------------
SECRET_KEY=your-secret-key-minimum-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
FRONTEND_URL=http://localhost:5173

# ----------------------------------------------------------------
# Database
# ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://username:password@localhost/socialspace

# ----------------------------------------------------------------
# AI Providers (Groq is primary, others are fallback)
# ----------------------------------------------------------------
GROQ_API_KEY=your-groq-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ----------------------------------------------------------------
# Telegram (free, no paid tier required)
# Get token from @BotFather on Telegram
# ----------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ----------------------------------------------------------------
# Discord (free, no paid tier required)
# Get token from discord.com/developers/applications
# ----------------------------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# ----------------------------------------------------------------
# Twitter / X (OAuth 2.0 PKCE)
# Get from developer.twitter.com
# Note: posting requires $100/mo Basic API tier
# ----------------------------------------------------------------
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:8000/api/auth/twitter/callback

# ----------------------------------------------------------------
# Reddit (OAuth 2.0)
# Requires approval via Reddit Responsible Builder Policy
# ----------------------------------------------------------------
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:8000/api/reddit/callback